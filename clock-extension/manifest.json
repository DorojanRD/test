{
  "manifest_version": 3,
  "name": "Advanced Clock Extension",
  "version": "2.0",
  "description": "Extensie cu ceas, dată și calendar interactiv",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ceas & Calendar"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["tooltip.js"],
      "css": ["tooltip.css"]
    }
  ],
  "permissions": ["activeTab"]
}